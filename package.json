{
  "name": "sportsbag-cms-new",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "preview": "vite preview",
    "test": "vitest",
    "db:push": "drizzle-kit push:mysql",
    "db:generate": "drizzle-kit generate:mysql"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "drizzle-orm": "^0.28.0",
    "mysql2": "^3.6.0",
    "dotenv": "^16.4.5",
    "superjson": "^2.2.1",
    "zod": "^3.23.8",
    "sonner": "^1.5.0",
    "react-router-dom": "^6.26.0",
    "lucide-react": "^0.408.0",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.40",
    "autoprefixer": "^10.4.19"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "@types/node": "^20.14.10",
    "@types/express": "^4.17.21",
    "vite": "^5.3.4",
    "@vitejs/plugin-react": "^4.3.1",
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.16.2",
    "vitest": "^2.0.4"
  }
